NODE_ENV=production
PORT=4000

# Website origins allowed to call the API.
APP_ORIGINS=https://bsb-international-school.vercel.app,http://localhost:5173
ALLOW_VERCEL_PREVIEWS=true

# Authentication
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=12h

# Online MySQL database
MYSQL_HOST=your-mysql-cloud-host
MYSQL_PORT=3306
MYSQL_DATABASE=bsb_erp
MYSQL_USER=your_mysql_user
MYSQL_PASSWORD=your_mysql_password

# Public URL of the deployed API, used for uploaded document links.
UPLOAD_BASE_URL=https://your-api-service.onrender.com

# Email notifications
CONTACT_RECEIVER_EMAIL=akash.gita.bhagwat@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_email
SMTP_PASS=your_smtp_app_password
MAIL_FROM=BSB International School <your_smtp_email>

# Optional SMS / WhatsApp integrations
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
ADMIN_NOTIFICATION_WHATSAPP=

# Backups
MYSQL_DUMP_BIN=mysqldump
