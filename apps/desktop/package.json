{
  "name": "@bsb/desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on tcp:5174 && cross-env VITE_DEV_SERVER_URL=http://localhost:5174 electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder",
    "lint": "node -e \"console.log('Add ESLint if needed')\""
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^31.7.6",
    "electron-builder": "^24.13.3",
    "vite": "^5.4.1",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.bsb.school.erp",
    "productName": "BSB International School ERP",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
